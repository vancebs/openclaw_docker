# 镜像配置 (WARNNING: 配置后将覆盖后续版本更新，你将需要自己维护openclaw版本!!)
#OPENCLAW_BASE_IMAGE=ghcr.io/openclaw/openclaw:2026.3.13-1

# 网关配置
#OPENCLAW_GATEWAY_PORT=18789
#OPENCLAW_BRIDGE_PORT=18790
#OPENCLAW_GATEWAY_TOKEN=claw
#OPENCLAW_GATEWAY_ALLOWED_IP="192.168.3.100 192.168.10.100" # localhost和127.0.0.1以外需要访问控制后台的IP。配置后将以https://<ip>访问
#OPENCLAW_GATEWAY_HTTPS_PORT=443
#OPENCLAW_GATEWAY_DNS1= # 默认223.5.5.5
#OPENCLAW_GATEWAY_DNS2= # 默认1.1.1.1

# Claude 集成（可选，仅使用 Claude 作为后端时填写）
#CLAUDE_AI_SESSION_KEY=
#CLAUDE_WEB_SESSION_KEY=
#CLAUDE_WEB_COOKIE=

# Proxy
#HTTP_PROXY=
#HTTPS_PROXY=
#NO_PROXY=localhost,127.0.0.1

# ── Caddy ─────────────────────────────────────────────────────────────────────
# 如果你没有自己的https反向代理，那么配置ENABLE_CADDY=1。
# 注意：
# 1. 这个配置项会读取OPENCLAW_GATEWAY_ALLOWED_IP和OPENCLAW_GATEWAY_HTTPS_PORT用于配置caddy服务。
# 2. 如果OPENCLAW_GATEWAY_ALLOWED_IP未设置，caddy服务并不会实际启动
# 3. 如果你自己配置https反向代理，请注意需要同OPENCLAW_GATEWAY_ALLOWED_IP和OPENCLAW_GATEWAY_HTTPS_PORT匹配
#ENABLE_CADDY=1

# 不知道这个ID，可以先不配。等发送消息后去log中找类似下面的log。sender后面就是。
#   - 如: feishu[default]: sender ou_xxxxxxxxxxx not in DM allowlist
#FEISHU_ALLOW_FROM=


