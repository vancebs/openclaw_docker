# 镜像配置
OPENCLAW_IMAGE=openclaw-hf:local
#OPENCLAW_BASE_IMAGE=ghcr.io/openclaw/openclaw:latest
OPENCLAW_BASE_IMAGE=ghcr.io/openclaw/openclaw:2026.3.8

# Volume
OPENCLAW_HOME_VOLUME=openclaw_home

# 网关配置
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_GATEWAY_TOKEN=claw
#OPENCLAW_GATEWAY_ALLOWED_IP="192.168.3.200 192.168.10.200" # localhost和127.0.0.1以外需要访问控制后台的IP。配置后将以https://<ip>访问

# Claude 集成（可选，仅使用 Claude 作为后端时填写）
CLAUDE_AI_SESSION_KEY=
CLAUDE_WEB_SESSION_KEY=
CLAUDE_WEB_COOKIE=

# Proxy
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1

# Caddy
ENABLE_CADDY=1 # 如果你有自己的https反向代理，那么注释掉这一行


# ── Star Office UI ────────────────────────────────────────────────────────────
STAR_OFFICE_PORT=18791
STAR_OFFICE_DATA_VOLUME=star_office_data

# REQUIRED in production: set strong random values
FLASK_SECRET_KEY=replace_with_password_longer_than_24 # length >= 24
ASSET_DRAWER_PASS=replace_with_password_longer_than_8 # length >= 8

# Optional Gemini integration (AI background generation)
GEMINI_API_KEY=
GEMINI_MODEL=nanobanana-pro
STAR_OFFICE_ENV=production
